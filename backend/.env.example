# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
WEB_APP_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public

# ── JWT access tokens (short lived) ───────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TTL=900s

# ── Refresh tokens (opaque, long lived) ───────────────────────
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_COOKIE=refresh_token

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── SMTP / Email (Mailpit by default for local dev) ───────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
MAIL_FROM="Acme Store <no-reply@acme.test>"

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# ── Redis / job queue ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Set to false to run workers inline (no Redis required, dev only)
QUEUE_ENABLED=true

# ── Checkout ──────────────────────────────────────────────────
ORDER_RESERVATION_TTL_MINUTES=30

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ── AI (pluggable providers) ──────────────────────────────────
# Provider per capability: huggingface | openai | none
# "openai" means any OpenAI-compatible endpoint (TGI / vLLM / Ollama / TEI).
AI_CHAT_PROVIDER=none
AI_EMBEDDING_PROVIDER=none
# Must match the embedding model's output size AND the products.embedding column (vector(384)).
AI_EMBEDDING_DIM=384
AI_MAX_CONTEXT_PRODUCTS=8

# Hugging Face Inference API
HF_API_KEY=
HF_BASE_URL=https://api-inference.huggingface.co
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# OpenAI-compatible server (TGI / vLLM / Ollama / TEI)
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
OPENAI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
